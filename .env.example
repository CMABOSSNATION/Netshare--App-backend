# NetShare Business Platform — Environment Variables
# Copy this file to .env and fill in your values

PORT=4000

# Admin password — change this immediately in production!
ADMIN_PASSWORD=NETSHARE_ADMIN_2024

# Max clients per host session
MAX_CLIENTS_PER_HOST=5

# Session timeout in milliseconds (default 1 hour)
SESSION_TIMEOUT_MS=3600000

# Hourly rate paid to hosts (in USD)
# Platform takes 50%, host keeps 50%
# Example: if plan costs $2/hr, set this to 1.00
HOURLY_RATE_PER_HOST=1.00
